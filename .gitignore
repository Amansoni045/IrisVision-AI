# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#1310, pipenv manages dependencies within Pipfile, and it is recommended
#   to check these in to version control.
#   However, in case you're system wide, you can ignore these:
#Pipfile.lock

# poetry
#   Similar to Pipenv, poetry manages dependencies within pyproject.toml and poetry.lock
#   poetry.lock

# pdm
#   Similar to Poetry and Pipenv, pdm manages dependencies within pyproject.toml and pdm.lock
# pdm.lock
#   pdm build stage
.pdm-build/

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyder-py3

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# Model Weights and caches (optional to ignore, but we want to track them so they are pre-downloaded)
